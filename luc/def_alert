// --- Click Inspector ---
Map.onClick(function(coords) {
  var zoom   = Map.getZoom();
  var thresh = 0.05 / Math.pow(2, Math.max(0, zoom - 5));

  // 1. Nearest centroid
  var best = null, bestDist = 1e9;
  for (var c = 0; c < uploadedFeatures.length; c++) {
    var cen = uploadedFeatures[c].centroid;
    if (!cen) continue;
    var dx = coords.lon - cen[0], dy = coords.lat - cen[1];
    var d  = Math.sqrt(dx * dx + dy * dy);
    if (d < bestDist) { bestDist = d; best = uploadedFeatures[c]; }
  }
  if (best && bestDist <= thresh) { showPopup(best.properties); return; }

  // 2. Polygon hit test
  for (var i = 0; i < uploadedFeatures.length; i++) {
    if (uploadedFeatures[i].geometry &&
        pointInPolygon([coords.lon, coords.lat], uploadedFeatures[i].geometry)) {
      showPopup(uploadedFeatures[i].properties);
      return;
    }
  }

  // 3. Pixel inspection (no polygon hit)
  popupPanel.style().set('shown', false);
  var pt = ee.Geometry.Point(coords.lon, coords.lat);
  var sampleImg = ee.Image.cat([
    sbtn_mask.rename('sbtn_forest_2020'),
    primary_2020.rename('gfw_forest_2020'),
    eufo_mask.rename('jrc_forest_2020'),
    sbtn_loss_total.rename('sbtn_loss_multisensor'),
    gfw_loss_total.rename('gfw_loss_multisensor'),
    jrc_deforestation.rename('jrc_loss_2021_2024'),
    radd_sbtn_all.rename('radd_sbtn_alert'),
    radd_gfw_all.rename('radd_gfw_alert'),
    radd_sbtn_high.rename('radd_sbtn_high_conf'),
    radd_gfw_high.rename('radd_gfw_high_conf')
  ]);
  var result = sampleImg.reduceRegion({
    reducer: ee.Reducer.first(),
    geometry: pt,
    scale: 30,
    maxPixels: 1
  });
  print('=== PIXEL INSPECTION ===');
  print('Coordinates:', coords);
  print('Multi-sensor values at point:', result);
});


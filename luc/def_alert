var uploadedPolygonsLayer = null;
var uploadedPointsLayer   = null;
var uploadedFeatures      = [];

var sampleGeoJSON = '{"type":"FeatureCollection","features":[{"type":"Feature","properties":{"ProducerName":"Sample Producer","ProducerCountry":"ID","ProductionPlace":"PLOT-001","Area":0.81},"geometry":{"type":"Polygon","coordinates":[[[110.4,-7.8],[110.5,-7.8],[110.5,-7.9],[110.4,-7.9],[110.4,-7.8]]]}}]}';

var updateStatus = function(msg, color) {
  statusPanel.clear();
  statusPanel.add(ui.Label(msg, { fontSize: '10px', color: color || '#546e7a', margin: '0' }));
};

var polygonCentroid = function(geom) {
  var coords = geom.coordinates[0];
  var x = 0, y = 0;
  for (var i = 0; i < coords.length; i++) { x += coords[i][0]; y += coords[i][1]; }
  return [x / coords.length, y / coords.length];
};

var pointInPolygon = function(pt, geom) {
  var x = pt[0], y = pt[1];
  var coords = geom.coordinates[0];
  var inside = false;
  for (var i = 0, j = coords.length - 1; i < coords.length; j = i++) {
    var xi = coords[i][0], yi = coords[i][1];
    var xj = coords[j][0], yj = coords[j][1];
    if (((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) inside = !inside;
  }
  return inside;
};

var showPopup = function(props) {
  popupBody.clear();
  var makeRow2 = function(label, val) {

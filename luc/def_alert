// Multi-sensor combined loss
Map.addLayer(sbtn_loss_total.updateMask(sbtn_loss_total.gt(0)), VIS.loss_sbtn, '4. SBTN Loss 2021-2025 (Multi-sensor)', true);
Map.addLayer(gfw_loss_total.updateMask(gfw_loss_total.gt(0)),   VIS.loss_gfw,  '5. GFW Loss 2021-2025 (Multi-sensor)',  true);
Map.addLayer(jrc_deforestation.updateMask(jrc_deforestation.gt(0)), VIS.loss_jrc, '6. JRC Deforestation 2021-2024',    true);

// RADD-only layers (toggle for comparison)
Map.addLayer(radd_sbtn_all.updateMask(radd_sbtn_all.gt(0)),   VIS.radd_all,  '7. RADD × SBTN (All confidence)',   false);
Map.addLayer(radd_gfw_all.updateMask(radd_gfw_all.gt(0)),     VIS.radd_all,  '8. RADD × GFW (All confidence)',    false);
Map.addLayer(radd_sbtn_high.updateMask(radd_sbtn_high.gt(0)), VIS.radd_high, '9. RADD × SBTN (High conf only)',   false);
Map.addLayer(radd_gfw_high.updateMask(radd_gfw_high.gt(0)),   VIS.radd_high, '10. RADD × GFW (High conf only)',   false);

// Hansen year splits (off by default)
Map.addLayer(sbtn_loss_2021_2023.updateMask(sbtn_loss_2021_2023.gt(0)), VIS.loss_sbtn, '11. SBTN Loss 2021-2023 (Hansen)', false);
Map.addLayer(sbtn_loss_2024_only.updateMask(sbtn_loss_2024_only.gt(0)), VIS.loss_sbtn, '12. SBTN Loss 2024 (Hansen)',      false);
Map.addLayer(gfw_loss_2021_2023.updateMask(gfw_loss_2021_2023.gt(0)),   VIS.loss_gfw,  '13. GFW Loss 2021-2023 (Hansen)',  false);
Map.addLayer(gfw_loss_2024_only.updateMask(gfw_loss_2024_only.gt(0)),   VIS.loss_gfw,  '14. GFW Loss 2024 (Hansen)',       false);


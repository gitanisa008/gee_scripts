var displayPolygons = function() {
  var text = geojsonTextbox.getValue();
  if (!text || text.trim() === '') {
    updateStatus('Please paste GeoJSON first.', '#e65100');
    return;
  }
  try {
    var data = JSON.parse(text);
    clearPolygons();
    if (data.type !== 'FeatureCollection' || !data.features || data.features.length === 0) {
      throw new Error('Not a valid FeatureCollection.');
    }
    var features = data.features;
    var geoErrors = validateGeoJSON(features);
    updateStatus('Loading ' + features.length + ' plots...', '#1565c0');
    var eeFeatures = [];
    uploadedFeatures = [];
    for (var i = 0; i < features.length; i++) {
      var f    = features[i];
      var geom = ee.Geometry(f.geometry);
      var props = f.properties || {};
      eeFeatures.push(ee.Feature(geom, props));
      uploadedFeatures.push({ geometry: f.geometry, properties: props, eeGeom: geom });
    }
    var fc = ee.FeatureCollection(eeFeatures);
    uploadedPolygonsLayer = ui.Map.Layer(fc, {
      color: '#0288d1', fillColor: '4fc3f730', width: 2
    }, 'Uploaded Plots (' + features.length + ')');
    Map.add(uploadedPolygonsLayer);
    Map.centerObject(fc, 12);
    if (geoErrors.length > 0) {
      updateStatus('GeoJSON invalid — ' + geoErrors[0] +
        (geoErrors.length > 1 ? ' (+' + (geoErrors.length - 1) + ' more issue(s))' : ''), '#b71c1c');
    } else {
      updateStatus(features.length + ' plots loaded. GeoJSON valid ✓', '#2e7d32');
    }
  } catch (e) {
    updateStatus('Parse error: ' + e.message, '#b71c1c');
  }
};


Map.addLayer(sbtn_mask.updateMask(sbtn_mask),              VIS.forest_sbtn, '1. SBTN Natural Lands 2020',   true);
Map.addLayer(primary_2020.updateMask(primary_2020.gt(0)),  VIS.forest_gfw,  '2. GFW Primary Forest 2020',   true);

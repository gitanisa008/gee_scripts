// ============================================================
// MULTI-SENSOR DEFORESTATION MONITORING TOOL
// Portfolio Version | Optical + Radar Fusion Approach
// Reference baseline: December 31, 2020 (aligned with EUDR)
// Sensors: Hansen GFC, GLAD, JRC TMF + RADD (Sentinel-1 SAR)
// ============================================================

Map.setOptions('HYBRID');

// ============================================================
// SECTION 1: DATASET INITIALIZATION
// ============================================================

// --- GFW Primary Forest Baseline ---
var primary_2001_raw = ee.ImageCollection("UMD/GLAD/PRIMARY_HUMID_TROPICAL_FORESTS/v1")
  .select("Primary_HT_forests").mosaic();

var gfc = ee.Image("UMD/hansen/global_forest_change_2024_v1_12");
var lossyear = gfc.select("lossyear");

// Derive primary forest 2020 (remove loss 2001–2020)
var loss_2001_2020  = lossyear.gte(1).and(lossyear.lte(20));
var primary_2020    = primary_2001_raw.where(loss_2001_2020, 0).unmask(0);
var primary_mask_2020 = primary_2020.unmask(0);

// --- SBTN Natural Lands 2020 ---
var sbtn      = ee.Image('WRI/SBTN/naturalLands/v1_1/2020').select('natural');
var sbtn_mask = sbtn.eq(1);

// --- JRC Global Forest Cover 2020 ---
var eufo      = ee.ImageCollection("JRC/GFC2020/V2").mosaic().rename("EUFO_2020");
var eufo_mask = eufo.gt(0);

// --- Hansen Loss by Year (post-2020) ---
var loss_2021_2023 = lossyear.gte(21).and(lossyear.lte(23));
var loss_2024      = lossyear.eq(24);
var loss_2021_2024 = lossyear.gte(21).and(lossyear.lte(24));

// --- JRC TMF Deforestation 2021–2024 ---
var tmf_def = ee.ImageCollection("projects/JRC/TMF/v1_2024/DeforestationYear").mosaic();
var jrc_deforestation = tmf_def.gte(2021).and(tmf_def.lte(2024))
  .updateMask(eufo_mask).rename('jrc_deforestation');

// --- GLAD Optical Alerts 2025 (Landsat/Sentinel-2) ---
var glad_col = ee.ImageCollection('projects/glad/alert/UpdResult')
  .map(function(img) { return img.select(['conf25', 'alertDate25']); });
var glad_latest      = glad_col.mosaic();
var glad_2025_alerts = glad_latest.select('conf25').gt(0)
  .and(glad_latest.select('alertDate25').gt(0));

// --- RADD Alerts (Sentinel-1 SAR | Wageningen University) ---
// Dataset: projects/radar-wur/raddalert/v1
// Alert band encoding: 2 = low confidence, 3 = high confidence
// Date band: days since Dec 31 2018 | day 731 = Dec 31 2020 (EUDR cutoff)
// Coverage: humid tropical forests (incl. insular SE Asia)
var radd_col = ee.ImageCollection('projects/radar-wur/raddalert/v1')
  .filter(ee.Filter.listContains('system:band_names', 'Alert'))
  .filter(ee.Filter.listContains('system:band_names', 'Date'));
var radd_img  = radd_col.select(['Alert', 'Date']).mosaic();
var radd_conf = radd_img.select('Alert');   
var radd_date = radd_img.select('Date');    

// Filter: post-2020 cutoff (day > 731)
var radd_post2020  = radd_date.gt(731);
var radd_all_conf  = radd_post2020.and(radd_conf.gte(2)); // low + high
var radd_high_conf = radd_post2020.and(radd_conf.gte(3)); // high only

// RADD × forest masks
var radd_sbtn_all   = radd_all_conf.multiply(sbtn_mask).unmask(0).rename('radd_sbtn_all');
var radd_gfw_all    = radd_all_conf.multiply(primary_mask_2020).unmask(0).rename('radd_gfw_all');
var radd_sbtn_high  = radd_high_conf.multiply(sbtn_mask).unmask(0).rename('radd_sbtn_high');
var radd_gfw_high   = radd_high_conf.multiply(primary_mask_2020).unmask(0).rename('radd_gfw_high');

// ============================================================
// SECTION 2: COMBINED MULTI-SENSOR LOSS LAYERS
// ============================================================

// Hansen (2021–2024) + GLAD Optical (2025) + RADD Radar (post-2020)

// SBTN combined
var sbtn_loss_hansen = loss_2021_2024.multiply(sbtn_mask).unmask(0);
var sbtn_loss_glad   = glad_2025_alerts.multiply(sbtn_mask).unmask(0);
var sbtn_loss_total  = sbtn_loss_hansen.or(sbtn_loss_glad).or(radd_sbtn_all)
  .rename('sbtn_loss_total');

// GFW combined
var gfw_loss_hansen = loss_2021_2024.multiply(primary_mask_2020).unmask(0);
var gfw_loss_glad   = glad_2025_alerts.multiply(primary_mask_2020).unmask(0);
var gfw_loss_total  = gfw_loss_hansen.or(gfw_loss_glad).or(radd_gfw_all)
  .rename('gfw_loss_total');

// Hansen-only splits (for comparison)
var sbtn_loss_2021_2023 = loss_2021_2023.multiply(sbtn_mask).unmask(0);
var sbtn_loss_2024_only = loss_2024.multiply(sbtn_mask).unmask(0);
var gfw_loss_2021_2023  = loss_2021_2023.multiply(primary_mask_2020).unmask(0);
var gfw_loss_2024_only  = loss_2024.multiply(primary_mask_2020).unmask(0);

// ============================================================
// SECTION 3: VISUALIZATION PARAMETERS
// ============================================================

var VIS = {
  forest_sbtn:   { min: 1, max: 1, palette: ['#1a9850'] }, // green
  forest_gfw:    { min: 1, max: 1, palette: ['#006837'] }, // dark green
  forest_jrc:    { min: 1, max: 1, palette: ['#66bd63'] }, // lime
  loss_sbtn:     { min: 1, max: 1, palette: ['#d73027'] }, // red
  loss_gfw:      { min: 1, max: 1, palette: ['#a50026'] }, // dark red
  loss_jrc:      { min: 1, max: 1, palette: ['#f46d43'] }, // orange-red
  radd_all:      { min: 1, max: 1, palette: ['#fdae61'] }, // amber — distinct from optical
  radd_high:     { min: 1, max: 1, palette: ['#f46d43'] }, // orange
};


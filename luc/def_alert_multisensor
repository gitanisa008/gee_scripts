// --- GeoJSON Validation Helpers (EUDR standard) ---
var calcSignedArea = function(ring) {
  var area = 0;
  for (var i = 0; i < ring.length - 1; i++) {
    area += (ring[i][0] * ring[i+1][1]) - (ring[i+1][0] * ring[i][1]);
  }
  return area / 2;
};

var segDirection = function(pi, pj, pk) {
  return (pk[0] - pi[0]) * (pj[1] - pi[1]) - (pj[0] - pi[0]) * (pk[1] - pi[1]);
};

var segmentsIntersect = function(a, b, c, d) {
  var d1 = segDirection(c, d, a), d2 = segDirection(c, d, b);
  var d3 = segDirection(a, b, c), d4 = segDirection(a, b, d);
  return ((d1 > 0 && d2 < 0) || (d1 < 0 && d2 > 0)) &&
         ((d3 > 0 && d4 < 0) || (d3 < 0 && d4 > 0));
};

var hasSelfIntersect = function(ring) {
  var n = ring.length - 1;
  for (var i = 0; i < n - 1; i++) {
    for (var j = i + 2; j < n; j++) {
      if (i === 0 && j === n - 1) continue;
      if (segmentsIntersect(ring[i], ring[i+1], ring[j], ring[j+1])) return true;
    }
  }
  return false;
};

var validateGeoJSON = function(features) {
  var errors = [];
  for (var i = 0; i < features.length; i++) {
    var f    = features[i];
    var name = (f.properties &&
                (f.properties.ProductionPlace || f.properties.name || f.properties.id)) ||
               ('Feature ' + (i + 1));
    var geom = f.geometry;
    if (!geom || geom.type !== 'Polygon') continue;

    var rings = geom.coordinates;
    var ext   = rings[0];

    // 1. Closed loop check
    var first = ext[0], last = ext[ext.length - 1];
    if (first[0] !== last[0] || first[1] !== last[1]) {
      errors.push(name + ': exterior ring not closed');
    }

    // 2. Exterior ring must be CCW
    if (calcSignedArea(ext) < 0) {
      errors.push(name + ': exterior ring is CW (must be CCW per GeoJSON/EUDR)');
    }

    // 3. Interior rings (holes) must be CW
    for (var h = 1; h < rings.length; h++) {
      if (calcSignedArea(rings[h]) > 0) {
        errors.push(name + ': interior ring ' + h + ' is CCW (holes must be CW per EUDR)');
      }
    }

    // 4. Self-intersect check
    if (hasSelfIntersect(ext)) {
      errors.push(name + ': self-intersecting ring');
    }

    // 5. Coordinate precision: minimum 6 decimal digits (EUDR)
    var lowPrec = false;
    for (var p = 0; p < ext.length && !lowPrec; p++) {
      var lonStr = String(ext[p][0]), latStr = String(ext[p][1]);
      var lonDec = lonStr.indexOf('.') >= 0 ? lonStr.split('.')[1].length : 0;
      var latDec = latStr.indexOf('.') >= 0 ? latStr.split('.')[1].length : 0;
      if (lonDec < 6 || latDec < 6) lowPrec = true;
    }
    if (lowPrec) {
      errors.push(name + ': coordinates must have \u2265 6 decimal places (EUDR precision)');
    }
  }
  return errors;
};

// --- KLHK Overlay Analysis ---
var computeKLHK = function(eeGeom, callback) {
  var intersecting   = klhk.filterBounds(eeGeom);
  var keteranganList = intersecting.aggregate_array('keterangan');
  keteranganList.evaluate(function(vals, err) {
    if (err || !vals || vals.length === 0) { callback('Unknown', []); return; }
    var unique = [], seen = {};
    for (var i = 0; i < vals.length; i++) {
      if (!seen[vals[i]]) { seen[vals[i]] = true; unique.push(vals[i]); }
    }
    var safeOnly = true;
    for (var j = 0; j < unique.length; j++) {
      var isSafeType = false;
      for (var k = 0; k < klhkSafeCats.length; k++) {
        if (unique[j] === klhkSafeCats[k]) { isSafeType = true; break; }
      }
      if (!isSafeType) { safeOnly = false; break; }
    }
    callback(safeOnly ? 'SAFE' : 'PROTECTED', unique);
  });
};


});
clearBtn.onClick(clearPolygons);

Map.onClick(function(coords) {
  for (var i = 0; i < uploadedFeatures.length; i++) {
    if (uploadedFeatures[i].geometry &&
        pointInPolygon([coords.lon, coords.lat], uploadedFeatures[i].geometry)) {
      showPopup(uploadedFeatures[i].properties, uploadedFeatures[i].eeGeom);
      return;
    }
  }
});   

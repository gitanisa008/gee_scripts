// ============================================================
// SECTION 1: DATASET INITIALIZATION
// ============================================================
var idn = ee.FeatureCollection("FAO/GAUL/2015/level1")
  .filter(ee.Filter.eq('ADM0_NAME', 'Indonesia'));
  
// --- JRC Global Forest Cover 2020 ---
var jrc      = ee.Image("JRC/GFC2020/V3");
var forest_jrc = jrc.gt(0).clip(idn)

// --- JRC  Deforestation 2021-2025 ---
var tmf = ee.ImageCollection("projects/JRC/TMF/v1_2025/DeforestationYear").mosaic();
var loss_jrc = tmf.gte(2021).and(tmf.lte(2025))
              .clip(idn)

// --- GLAD Optical Alerts 2025 (Landsat/Sentinel-2) ---
var glad = ee.ImageCollection('projects/glad/alert/UpdResult')
  .map(function(img) { return img.select(['conf25', 'alertDate25']); });
var glad_latest      = glad.mosaic();
var glad_alerts = glad_latest.select('conf25').gt(0)
  .and(glad_latest.select('alertDate25').gt(0));

// --- RADD Alerts (Sentinel-1 SAR | Wageningen University) ---
var radd_col = ee.ImageCollection('projects/radar-wur/raddalert/v1')
  .filter(ee.Filter.listContains('system:band_names', 'Alert'))
  .filter(ee.Filter.listContains('system:band_names', 'Date'));
var radd_img  = radd_col.select(['Alert', 'Date']).mosaic();
var radd_conf = radd_img.select('Alert');
var radd_date = radd_img.select('Date');

// Filter: post-2020 cutoff (day > 731)
var radd_post2020  = radd_date.gt(731);
var radd_all_conf  = radd_post2020.and(radd_conf.gte(2));
var radd_high_conf = radd_post2020.and(radd_conf.gte(3));

// ============================================================
// SECTION 2: LOGIC FOR MULTI SENSORS ALERT
// ============================================================

// RADD x forest masks
var radd_jrc  = radd_all_conf.multiply(loss_jrc).unmask(0).rename('radd_jrc');
var radd_glad = radd_all_conf.multiply(glad_alerts).unmask(0).rename('radd_glad');
var radd_jrc_high  = radd_high_conf.multiply(loss_jrc).unmask(0).rename('radd_jrc_high');
var radd_glad_high = radd_high_conf.multiply(glad_alerts).unmask(0).rename('radd_glad_high');


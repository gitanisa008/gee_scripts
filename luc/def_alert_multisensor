//map on click
var pointInPolygon = function(pt, geom) {
  var x = pt[0], y = pt[1];
  var coords = geom.coordinates[0];
  var inside = false;
  for (var i = 0, j = coords.length - 1; i < coords.length; j = i++) {
    var xi = coords[i][0], yi = coords[i][1];
    var xj = coords[j][0], yj = coords[j][1];
    if (((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) inside = !inside;
  }
  return inside;
};

var computeAlert = function(eeGeom, callback) {
  var combined = ee.Image.cat([
    glad_alerts.rename('glad_s2'),
    loss_jrc.rename('jrc_loss'),
    radd_all_conf.rename('radd')
  ]);

  var result = combined.reduceRegion({
    reducer: ee.Reducer.max(),
    geometry: eeGeom,
    scale: 30,
    maxPixels: 1e6
  });

  result.evaluate(function(val, err) {
    if (err) { callback('ERROR', []); return; }

    var hasGLAD = (val.glad_s2  !== null && val.glad_s2  > 0);
    var hasJRC  = (val.jrc_loss !== null && val.jrc_loss > 0);
    var hasRADD = (val.radd     !== null && val.radd     > 0);

    var sensorCount = (hasGLAD ? 1 : 0)
                    + (hasJRC  ? 1 : 0)
                    + (hasRADD ? 1 : 0);

    var level;
    if      (sensorCount === 3) level = 'HIGH';
    else if (sensorCount === 2) level = 'MEDIUM';
    else if (sensorCount === 1) level = 'LOW';
    else                        level = 'NO ALERT';

    var triggered = [
      hasGLAD ? 'GLAD-S2' : null,
      hasJRC  ? 'JRC'     : null,
      hasRADD ? 'RADD'    : null
    ].filter(function(x) { return x !== null; });

    callback(level, triggered);
  });
};

var showPopup = function(props, eeGeom) {
  popupBody.clear();
  var makeRow2 = function(label, val) {
    popupBody.add(ui.Panel({
      widgets: [
        ui.Label(label, { fontSize: '9px', color: '#90a4ae', margin: '2px 0 0 0', width: '95px' }),
        ui.Label(String(val !== undefined && val !== null ? val : 'N/A'), {
          fontSize: '11px', color: '#1b2631', fontWeight: 'bold', margin: '2px 0 0 0'
        })
      ],
      layout: ui.Panel.Layout.flow('horizontal')
    }));
  };
  makeRow2('Production Place', props.ProductionPlace);
  makeRow2('Area (ha)',        props.Area);

  var alertLabel = ui.Label('Computing alert...', {
    fontSize: '11px', color: '#546e7a', fontWeight: 'bold', margin: '8px 0 0 0'
  });
  var triggeredLabel = ui.Label('', {
    fontSize: '9px', color: '#546e7a', margin: '2px 0 0 0'
  });
  popupBody.add(alertLabel);
  popupBody.add(triggeredLabel);
  popupPanel.style().set('shown', true);

  // callback(level, triggered)
  computeAlert(eeGeom, function(level, triggered) {
    //  HIGH/MEDIUM/LOW/NO ALERT
    var alertColor = '#546e7a';
    if      (level === 'HIGH')     alertColor = '#b71c1c';
    else if (level === 'MEDIUM')   alertColor = '#e65100';
    else if (level === 'LOW')      alertColor = '#f9a825';
    else if (level === 'NO ALERT') alertColor = '#2e7d32';

    alertLabel.setValue('Alert: ' + level);
    alertLabel.style().set('color', alertColor);
    triggeredLabel.setValue(
      triggered.length > 0 ? 'Triggered: ' + triggered.join(', ') : 'No sensor triggered'
    );
  });
};

var clearPolygons = function() {
  if (uploadedPolygonsLayer) { Map.remove(uploadedPolygonsLayer); uploadedPolygonsLayer = null; }
  uploadedFeatures = [];
  popupPanel.style().set('shown', false);
  updateStatus('Cleared. Ready for new input.');
  Map.centerObject(ee.Geometry.Rectangle([95, -11, 141, 6]), 17);
};

var displayPolygons = function() {
  var text = geojsonTextbox.getValue();
  if (!text || text.trim() === '') {
    updateStatus('Please paste GeoJSON first.', '#e65100');
    return;
  }
  try {
    var data = JSON.parse(text);
    clearPolygons();
    if (data.type !== 'FeatureCollection' || !data.features || data.features.length === 0) {
      throw new Error('Not a valid FeatureCollection.');
    }
    var features = data.features;
    updateStatus('Loading ' + features.length + ' plots...', '#1565c0');
    var eeFeatures = [];
    uploadedFeatures = [];
    for (var i = 0; i < features.length; i++) {
      var f    = features[i];
      var geom = ee.Geometry(f.geometry);
      var props = f.properties || {};
      eeFeatures.push(ee.Feature(geom, props));
      uploadedFeatures.push({ geometry: f.geometry, properties: props, eeGeom: geom });
    }
    var fc = ee.FeatureCollection(eeFeatures);
    uploadedPolygonsLayer = ui.Map.Layer(fc, {
      color: '#0288d1', fillColor: '4fc3f730', width: 2
    }, 'Uploaded Plots (' + features.length + ')');
    Map.add(uploadedPolygonsLayer);
    Map.centerObject(fc, 12);
    updateStatus(features.length + ' plots loaded. Click to inspect.', '#2e7d32');
  } catch (e) {
    updateStatus('Parse error: ' + e.message, '#b71c1c');
  }
};

uploadBtn.onClick(displayPolygons);
sampleBtn.onClick(function() {
  geojsonTextbox.setValue(sampleGeoJSON);
